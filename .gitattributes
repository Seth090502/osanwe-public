# Default: treat all files as text, enforce LF on checkout
* text=auto eol=lf

# Explicit text files (user canon)
*.md        text eol=lf
*.base      text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.canvas    text eol=lf
*.svg       text eol=lf

# Vault-present additions (Group 1 audit 2026-04-17)
*.html      text eol=lf
*.ps1       text eol=lf
*.txt       text eol=lf
*.csv       text eol=lf
*.modelfile text eol=lf
Modelfile*  text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.obsidianignore text eol=lf

# Binary files — never convert
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.pdf       binary
*.zip       binary
*.webp      binary
*.7z        binary
*.tar       binary
*.gz        binary
*.mp3       binary
*.mp4       binary
*.wav       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.exe       binary
*.dll       binary
*.so        binary
